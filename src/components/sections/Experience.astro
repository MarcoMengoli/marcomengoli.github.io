---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import ScrollReveal from "@/components/ui/ScrollReveal.astro";
import TimelineItem from "@/components/ui/TimelineItem.astro";
import { experiences } from "@/data/experience";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="experience" class="px-6 py-24 sm:py-32">
  <div class="mx-auto max-w-3xl">
    <ScrollReveal>
      <SectionHeading>{t("experience.heading")}</SectionHeading>
    </ScrollReveal>

    <div class="mt-12">
      {
        experiences.map((exp, i) => (
          <ScrollReveal delay={i * 100}>
            <TimelineItem
              company={exp.company}
              role={exp.role[lang]}
              period={exp.period}
              description={exp.description[lang]}
              highlights={exp.highlights[lang]}
              technologies={exp.technologies}
              type={exp.type}
            />
          </ScrollReveal>
        ))
      }
    </div>
  </div>
</section>
