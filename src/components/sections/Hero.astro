---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="hero"
  class="relative flex min-h-screen items-center justify-center overflow-hidden px-6"
>
  <div class="mx-auto max-w-5xl text-center">
    <!-- Greeting -->
    <p
      class="mb-4 font-mono text-sm font-medium tracking-wider text-accent-500 uppercase"
    >
      {t("hero.greeting")}
    </p>

    <!-- Name -->
    <h1
      class="mb-6 text-5xl font-extrabold tracking-tight text-slate-900 dark:text-white sm:text-6xl md:text-7xl lg:text-8xl"
    >
      {t("hero.name")}
    </h1>

    <!-- Title -->
    <p
      class="mb-4 text-xl font-semibold text-accent-500 sm:text-2xl"
    >
      {t("hero.title")}
    </p>

    <!-- Subtitle -->
    <p
      class="mx-auto mb-10 max-w-2xl text-lg text-slate-600 dark:text-slate-400 sm:text-xl"
    >
      {t("hero.subtitle")}
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href="#contact"
        class="inline-flex items-center gap-2 rounded-lg bg-accent-500 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-accent-600 hover:shadow-lg hover:shadow-accent-500/25"
      >
        {t("hero.cta.contact")}
        <svg
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
        </svg>
      </a>
      <a
        href="/CV_MarcoMengoli.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-slate-300 px-6 py-3 text-sm font-semibold text-slate-700 transition-all hover:border-accent-500 hover:text-accent-500 dark:border-slate-700 dark:text-slate-300 dark:hover:border-accent-500 dark:hover:text-accent-400"
      >
        <svg
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"
          ></path>
        </svg>
        {t("hero.cta.cv")}
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
    <a
      href="#about"
      aria-label={t("hero.scroll")}
      class="flex flex-col items-center gap-2 text-slate-500 transition-colors hover:text-accent-500"
    >
      <svg
        class="h-5 w-5 animate-scroll-hint"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
      </svg>
    </a>
  </div>
</section>
