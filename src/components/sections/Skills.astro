---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import ScrollReveal from "@/components/ui/ScrollReveal.astro";
import SkillBadge from "@/components/ui/SkillBadge.astro";
import { skillCategories } from "@/data/skills";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="skills" class="px-6 py-24 sm:py-32">
  <div class="mx-auto max-w-5xl">
    <ScrollReveal>
      <SectionHeading>{t("skills.heading")}</SectionHeading>
    </ScrollReveal>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        skillCategories.map((cat, i) => (
          <ScrollReveal delay={i * 80}>
            <div class="rounded-xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900/50">
              <div class="mb-4 flex items-center gap-3">
                <span class="text-accent-500">
                  <Fragment set:html={cat.icon} />
                </span>
                <h3 class="text-sm font-semibold text-slate-900 dark:text-white">
                  {cat.name[lang]}
                </h3>
              </div>
              <div class="flex flex-wrap gap-2">
                {cat.skills.map((skill) => (
                  <SkillBadge name={skill} />
                ))}
              </div>
            </div>
          </ScrollReveal>
        ))
      }
    </div>
  </div>
</section>
