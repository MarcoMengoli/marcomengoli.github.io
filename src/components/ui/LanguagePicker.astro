---
import { getLangFromUrl } from "@/i18n/utils";
import { languages } from "@/i18n/ui";

const lang = getLangFromUrl(Astro.url);
const otherLang = lang === "en" ? "it" : "en";
const otherUrl = lang === "en" ? "/it/" : "/";
---

<a
  href={otherUrl}
  aria-label={`Switch to ${languages[otherLang]}`}
  class="flex h-9 items-center rounded-lg px-2.5 font-mono text-sm font-medium text-slate-600 transition-colors hover:text-slate-900 hover:bg-slate-100 dark:text-slate-400 dark:hover:text-white dark:hover:bg-slate-800"
>
  {otherLang.toUpperCase()}
</a>
