---
interface Props {
  company: string;
  role: string;
  period: string;
  description: string;
  highlights: string[];
  technologies: string[];
  type: "engineering" | "live-systems" | "volunteer";
}

const { company, role, period, description, highlights, technologies, type } =
  Astro.props;

const typeColors = {
  engineering: "bg-accent-500",
  "live-systems": "bg-amber-500",
  volunteer: "bg-emerald-500",
};

const dotColor = typeColors[type];
---

<div class="relative pl-8 pb-12 last:pb-0">
  <!-- Timeline line -->
  <div
    class="absolute left-[7px] top-3 -bottom-3 w-px bg-slate-200 dark:bg-slate-800 last:hidden"
  >
  </div>

  <!-- Timeline dot -->
  <div
    class:list={[
      "absolute left-0 top-2 h-[15px] w-[15px] rounded-full border-2 border-white dark:border-slate-950",
      dotColor,
    ]}
  >
  </div>

  <!-- Content -->
  <div class="rounded-xl border border-slate-200 bg-white p-5 transition-all hover:border-slate-300 dark:border-slate-800 dark:bg-slate-900/50 dark:hover:border-slate-700">
    <div class="mb-1 flex flex-wrap items-center gap-x-3 gap-y-1">
      <h3 class="text-lg font-bold text-slate-900 dark:text-white">
        {company}
      </h3>
      <span
        class="rounded-full bg-slate-100 px-2.5 py-0.5 font-mono text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-400"
      >
        {period}
      </span>
    </div>

    <p class="mb-3 text-sm font-semibold text-accent-500">{role}</p>

    <p class="mb-3 text-sm text-slate-600 dark:text-slate-400">
      {description}
    </p>

    {
      highlights.length > 0 && (
        <ul class="mb-4 space-y-1.5">
          {highlights.map((h) => (
            <li class="flex gap-2 text-sm text-slate-600 dark:text-slate-400">
              <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-accent-500" />
              {h}
            </li>
          ))}
        </ul>
      )
    }

    <div class="flex flex-wrap gap-1.5">
      {
        technologies.map((tech) => (
          <span class="rounded-md bg-slate-100 px-2 py-0.5 font-mono text-xs text-slate-600 dark:bg-slate-800 dark:text-slate-400">
            {tech}
          </span>
        ))
      }
    </div>
  </div>
</div>
