---
interface Props {
  class?: string;
  delay?: number;
}

const { class: className = "", delay = 0 } = Astro.props;
---

<div
  class:list={["opacity-0 translate-y-6 transition-none", className]}
  data-scroll-reveal
  data-delay={delay}
>
  <slot />
</div>

<script>
  function initScrollReveal() {
    const elements = document.querySelectorAll<HTMLElement>("[data-scroll-reveal]");

    // Respect reduced motion
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    if (prefersReducedMotion) {
      elements.forEach((el) => {
        el.classList.remove("opacity-0", "translate-y-6");
      });
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = Number(el.dataset.delay || 0);
            setTimeout(() => {
              el.classList.add("animate-fade-up");
              el.classList.remove("opacity-0", "translate-y-6", "transition-none");
            }, delay);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.1 }
    );

    elements.forEach((el) => observer.observe(el));
  }

  document.addEventListener("astro:page-load", initScrollReveal);
</script>
